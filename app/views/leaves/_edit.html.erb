<li class="toc__leaf toc__leaf--<%= leaf.leafable_name %> <%= local_assigns[:css_class] %>" id="<%= dom_id(leaf) %>">
  <%= link_to leafable_path(leaf), class: "toc__thumbnail", target: "_top" do %>
    <%= leaf.title if leaf.leafable.is_a?(Section) %>
    <%= leaf.leafable.body if leaf.leafable.is_a?(Page) %>
    <%= image_tag leaf.leafable.image.variant(:large) if leaf.leafable.is_a?(Picture) && leaf.leafable.image.attached? %>
  <% end %>

  <div class="toc__title flex align-center min-width">
    <%= form_with model: [ leaf.book, leaf.leafable ], class: "flex align-center max-width min-width", id: dom_id(leaf, "form") do |form| %>
      <%= form.text_field :title, class: "input full-width", autofocus: true, autocomplete: "off", data: { controller: "autoselect" } %>
    <% end %>

    <span class="flex align-center gap-half">
      <button type="submit" class="btn txt-small btn--positive" form="<%= dom_id(leaf, "form") %>">
        <%= image_tag "check.svg", aria: { hidden: true }, size: 24 %>
        <span class="for-screen-reader">Save</span>
      </button>

      <%= button_to leafable_path(leaf), method: :delete, class: "btn btn--negative txt-small" do %>
        <%= image_tag "trash.svg", aria: { hidden: true }, size: 24 %>
        <span class="for-screen-reader">Delete this page</span>
      <% end %>
    </span>
  </div>

  <small class="toc__wordcount translucent">
    <% if leaf.leafable.is_a?(Page) %>
      <%= word_count(leaf.leafable.body.content) %>
    <% end %>
  </small>

  <%= yield if block_given? %>
</li>
