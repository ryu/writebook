<li class="toc__leaf toc__leaf--<%= leaf.leafable_name %> <%= local_assigns[:css_class] %>" id="<%= dom_id(leaf) %>" data-arrangement-target="item" data-id="<%= leaf.id %>">
  <%= image_tag "handle.svg", aria: { hidden: true }, size: 24, class: "toc__handle translucent colorize--black" %>

  <div class="toc__thumbnail">
    <%= link_to "Open #{ leaf.title }", leafable_path(leaf), class: "toc__link", target: "_top" %>
    <%= leaf.title if leaf.leafable.is_a?(Section) %>
    <%= render_markdown leaf.leafable.body if leaf.leafable.is_a?(Page) && leaf.leafable&.body && leaf.leafable.is_a?(Page) %>
    <%= image_tag leaf.leafable.image.variant(:large) if leaf.leafable.is_a?(Picture) && leaf.leafable.image.attached? %>
  </div>

  <%= link_to leafable_path(leaf), class: "toc__title min-width", target: "_top" do %>
    <span class="overflow-ellipsis"><%= leaf.title %></span>
  <% end %>

  <small class="toc__wordcount translucent">
    <% if leaf.leafable.is_a?(Page) %>
      <%= word_count(leaf.leafable.body) %>
    <% end %>
  </small>

  <%= yield if block_given? %>
</li>
