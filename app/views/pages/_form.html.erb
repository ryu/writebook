<%= form_with model: [ book, page ], id: "page-editor", format: :html do |form| %>
  <%= house_field "page[body]", page.body.content, toolbar: "house_toolbar",
        data: { uploads_url: action_text_markdown_uploads_url(record_gid: page.to_signed_global_id.to_s, attribute_name: "body") },
        required: true, autofocus: true, class: "page__editor" %>
<% end %>
