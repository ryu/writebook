<% content_for(:title) { "Edit #{ @page.title }" } %>

<% content_for :header do %>
  <nav>
    <%= link_to_previous_leafable(@leaf, hotkey: false) %>

    <div class="breadcrumbs">
      <%= link_to books_path do %>
        <%= image_tag "books.svg", aria: { label: "Books" }, size: 19, class: "colorize--black", alt: "Books" %>
      <% end %> ▸
      <%= link_to @book.title, @book %> ▸
      <%= form_with model: [ @book, @leaf ], url: leafable_path(@leaf), class: "flex align-center gap-half", format: :html do |form| %>
        <strong><%= form.text_field :title, form: "page-editor", class: "input full-width", autocomplete: "off" %></strong>
      <% end %>
    </div>

    <button class="btn flex-item-justify-end" data-action="fullscreen#toggle">
      <%= image_tag "expand.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Enter fullscreen</span>
    </button>
  </nav>
<% end %>

<article class="layout--reading">
  <%= render "leaves/being_edited_indicator", leaf: @leaf %>
  <div class="page__toolbar flex align-center gap fill-selected margin-block-end-double position-sticky">
    <%= render "house_toolbar" %>
    <button type="submit" form="page-editor" class="btn flex btn--positive flex-item-justify-end flex-item-no-shrink txt-small">
      <%= image_tag "check.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Save</span>
    </button>

    <span class="pad-inline" style="border-inline-start: 1px solid var(--color-subtle-dark)">
      <%= editing_mode_toggle_switch(leaf: @leaf) %>
    </span>
  </div>

  <%= render "pages/form", book: @book, page: @page %>
</article>

<%= render "leaves/edit_footer", leaf: @leaf %>
