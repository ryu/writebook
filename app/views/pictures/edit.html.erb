<% content_for(:title) { "Edit #{ @picture.title }" } %>
<% @layout_class = "page" %>

<% content_for :header do %>
  <nav>
    <%= link_to leafable_path(@leaf), class: "btn flex-item-justify-start" do %>
      <%= image_tag "remove.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Cancel</span>
    <% end %>

    <div class="breadcrumbs ">
      <%= form_with model: [ @book, @picture ], class: "flex align-center gap-half", format: :html do |form| %>
        <%= form.text_field :title, class: "input full-width", autocomplete: "off" %>
      <% end %>
    </div>

    <button type="submit" form="picture-editor", class="btn flex-item-justify-end">
      <%= image_tag "check.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Save</span>
    </button>
  </nav>
<% end %>

<div class="page--picture">
  <%= render "pictures/form", book: @book, picture: @picture %>
</div>

<% content_for :footer do %>
  <%= render "leaves/delete", leaf: @leaf %>
<% end %>
