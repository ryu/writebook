<% content_for(:title) { "Edit #{ @section.title }" } %>
<% @layout_class = "page" %>

<% content_for :header do %>
  <nav>
    <%= link_to leafable_path(@leaf), class: "btn flex-item-justify-start" do %>
      <%= image_tag "arrow-left.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Cancel changes and go back</span>
    <% end %>

    <div class="breadcrumbs">
      <%= link_to books_path do %>
        <%= image_tag "books.svg", aria: { label: "Books" }, size: 19, class: "colorize--black", alt: "Books" %>
      <% end %> ▸
      <%= link_to @book.title, @book %> ▸
      <strong><%= @section.title %></strong>
    </div>

    <button type="submit" form="section-editor", class="btn btn--positive flex-item-justify-end">
      <%= image_tag "check.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Save</span>
    </button>
  </nav>
<% end %>

<div class="page--section">
  <%= render "sections/form", book: @book, section: @section %>
</div>

<% content_for :footer do %>
  <span class="flex justify-start">
    <%= render "leaves/delete", leaf: @leaf %>
  </span>
<% end %>
